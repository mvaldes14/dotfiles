{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "effortLevel": "high",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_THEME": "dark"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Notification",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh PreToolUse",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/mvaldes/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh UserPromptSubmit",
            "type": "command"
          }
        ]
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "mcpServers": {
    "doit": {
      "type": "http",
      "url": "https://doit-mcp.int.mvaldes.dev/mcp"
    },
    "signoz": {
      "type": "http",
      "url": "https://signoz-mcp.int.mvaldes.dev/mcp"
    }
  },
  "model": "opus[1m]",
  "permissions": {
    "allow": [
      "Bash(helm show *)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "Bash(curl*doit.mvaldes.dev*)",
      "Bash(python3 -c *)",
      "Bash(gws calendar *)",
      "Bash(/usr/local/bin/obsidian *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "spinnerTipsEnabled": false,
  "statusLine": {
    "command": "~/git/dotfiles/claude/status_line.sh",
    "type": "command"
  },
  "tui": "fullscreen"
}