{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_THEME": "dark",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(helm show *)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "Bash(curl*doit.mvaldes.dev*)",
      "Bash(python3 -c *)",
      "Bash(gws calendar *)",
      "Bash(/usr/local/bin/obsidian *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh UserPromptSubmit"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh PreToolUse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Notification"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/git/dotfiles/claude/status_line.sh"
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "mcpServers": {
    "signoz": {
      "type": "http",
      "url": "https://signoz-mcp.int.mvaldes.dev/mcp"
    },
    "doit": {
      "type": "http",
      "url": "https://doit-mcp.int.mvaldes.dev/mcp"
    }
  }
}
