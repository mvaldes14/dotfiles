{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_THEME": "dark"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(helm show *)",
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "Bash(curl*doit.mvaldes.dev*)",
      "Bash(python3 -c *)",
      "Bash(gws calendar *)",
      "Bash(/usr/local/bin/obsidian *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Notification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh PreToolUse"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/mvaldes/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh Stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.tmux/plugins/tmux-agent-status/hooks/better-hook.sh UserPromptSubmit"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/git/dotfiles/claude/status_line.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "tmux-agent-sidebar@hiroppy": true
  },
  "extraKnownMarketplaces": {
    "hiroppy": {
      "source": {
        "source": "directory",
        "path": "/Users/mvaldes/.tmux/plugins/tmux-agent-sidebar"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "tui": "fullscreen",
  "mcpServers": {
    "doit": {
      "type": "http",
      "url": "https://doit-mcp.int.mvaldes.dev/mcp"
    },
    "signoz": {
      "type": "http",
      "url": "https://signoz-mcp.int.mvaldes.dev/mcp"
    }
  }
}
